{
  "name": "@aibrush/media",
  "version": "0.0.0",
  "description": "A unified, capability-routed, in-browser media engine — routes each operation to the best available substrate (WebCodecs → GPU → WASM → TS) behind a flat, intent-only API.",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "keywords": [
    "media",
    "video",
    "audio",
    "transcode",
    "webcodecs",
    "wasm",
    "mp4",
    "webm",
    "browser",
    "esm"
  ],
  "engines": {
    "node": ">=18"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.js"
    },
    "./image": {
      "types": "./dist/image.d.ts",
      "import": "./dist/image.js"
    },
    "./drivers/*": {
      "types": "./dist/drivers/*.d.ts",
      "import": "./dist/drivers/*.js"
    },
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.ts",
  "module": "./dist/index.js",
  "browser": {
    "module": false,
    "node:module": false,
    "fs": false,
    "node:fs": false,
    "path": false,
    "node:path": false,
    "crypto": false,
    "os": false,
    "url": false,
    "worker_threads": false
  },
  "files": ["dist"],
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test.json --noEmit && tsc -p tsconfig.scripts.json --noEmit",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "biome check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "test:dist": "vitest run src/dist-smoke.test.ts",
    "build": "tsup",
    "vendor-wasm": "bun run scripts/vendor-wasm.ts",
    "vendor-wasm:check": "bun run scripts/vendor-wasm.ts --check",
    "verify:package": "bun run vendor-wasm:check && bun run scripts/verify-package-install.ts",
    "check-budgets": "bun run scripts/check-budgets.ts",
    "fetch-fixtures": "bun run scripts/fetch-fixtures.ts",
    "bake-goldens": "bun run scripts/bake-goldens.ts",
    "bench-dsp": "bun run scripts/bench-dsp.ts",
    "bench-audio-stream": "bun run scripts/bench-audio-stream.ts",
    "bench-image": "bun run scripts/bench-image.ts",
    "bench-flac": "bun run scripts/bench-flac.ts",
    "bench-colorspace": "bun run scripts/bench-colorspace.ts",
    "bench-preload": "bun run scripts/bench-preload.ts",
    "bench-chain": "bun run scripts/bench-chain.ts",
    "bench-sources": "bun run scripts/bench-sources.ts",
    "bench-webm-fragment": "bun run scripts/bench-webm-fragment.ts",
    "bench-pool": "bun run scripts/bench-pool.ts",
    "bench-session6-r1": "bun run scripts/bench-session6-r1.ts",
    "bench-session6-r4": "bun run scripts/bench-session6-r4.ts",
    "verify:integrity": "bun run scripts/anti-cheat.ts",
    "gate": "bun run typecheck && biome check . && vitest run --coverage && tsup && bun run vendor-wasm && bun run test:dist && bun run check-budgets && bun run verify:package && bun run verify:integrity"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@vitest/coverage-v8": "^2.1.8",
    "@webgpu/types": "^0.1.70",
    "bun-types": "^1.3.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "trustedDependencies": ["@biomejs/biome"]
}
